{
    "manifest_version": 3,
    "name": "Grabber",
    "version": "0.1.0",
    "description": "it grabs.",

    "icons": {
        "48": "icons/icon48.png"
    },
    
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],

    "permissions": [
        "activeTab",
        "clipboardWrite",
        "downloads"
    ],

    "action": {
        "default_icon": "icons/icon48.png",
        "default_title": "Grabber"
    }
}