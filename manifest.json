{
    "manifest_version": 3,
    "name": "Grabber",
    "version": "0.1.0",
    "description": "it grabs.",

    "icons": {
        "48": "icons/icon48.png"
    },

    "background": {
        "scripts": ["background.js"]
    },
    
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["modules/thumbnail.js", "content.js"]
        }
    ],

    "permissions": [
        "activeTab",
        "clipboardWrite",
        "downloads",
        "nativeMessaging"
    ],

    "browser_specific_settings": {
        "gecko": {
            "id": "grabber@extension",
            "strict_min_version": "91.0"
        }
    },

    "action": {
        "default_icon": "icons/icon48.png",
        "default_title": "Grabber"
    }
}